# ─── Claude Code CLI ──────────────────────────────────────────────────────────
# The app spawns the `claude` CLI as a subprocess. Authenticate it once with:
#
#   claude auth login
#
# Alternatively, you can provide your Anthropic API key directly and the CLI
# will pick it up automatically:
#
# ANTHROPIC_API_KEY=sk-ant-...

# ─── Next.js server ───────────────────────────────────────────────────────────
PORT=3000
